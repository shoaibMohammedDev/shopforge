# ============================================================================
# ShopForge Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values for your environment.
# All variables are optional unless marked as [REQUIRED].

# [REQUIRED] Database connection string
# For SQLite (development): file:./db/custom.db
# For PostgreSQL (production): postgresql://user:password@localhost:5432/shopforge
DATABASE_URL=file:./db/custom.db

# Application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ShopForge

# Authentication (NextAuth.js)
NEXTAUTH_SECRET=

# Stripe Payments
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=

# Email (Resend.com)
RESEND_API_KEY=
EMAIL_FROM=noreply@shopforge.dev

# Redis (optional - for session storage / caching)
REDIS_URL=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
